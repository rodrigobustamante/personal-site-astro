---
import type { Features } from '~/types';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Button from '~/components/ui/Button.astro';
const { id, isDark = false, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props as Features;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <div class="flex flex-col gap-6">
    <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl">Experience</h2>
    <ol class="relative border-s border-gray-200 dark:border-gray-700">
      <li class="mb-10 ms-6">
        <span
          class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900"
        >
        </span>
        <h3 class="flex items-center mb-1 text-lg font-semibold text-gray-900 dark:text-white">
          LATAM Airlines
        </h3>
        <span>
          <span> Software Architect</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> October 2024 - March 2026 · Madrid, Remote</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Led the architecture and evolution of LATAM Airlines' Design System, establishing shared UI foundations adopted by 50+ teams across all digital platforms of Latin America's largest airline</li>
          <li>Designed and implemented a cross-platform design token system and theming strategy for React and React Native</li>
          <li>Built and maintained CI/CD pipelines (GitLab CI), cloud infrastructure on GCP (Cloud Run, Cloud SQL, Cloud Armor) and IaC with Terraform. Developed supporting tooling and automation scripts in Python</li>
          <li>Created MCP servers and AI-powered tooling using Python to improve team and agent productivity</li>
          <li>Optimized component performance and accessibility, enforcing WCAG compliance across critical user flows</li>
          <li>Mentored engineers across multiple squads on design system adoption and frontend best practices</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · React Native · Next.js · TypeScript · TailwindCSS · Storybook · GCP · Terraform · Docker · GitLab CI · Python · Redis
        </p>
        <span>
          <span> Senior Software Engineer</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> July 2023 - October 2024 · Santiago, Remote</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Owned frontend performance, SEO and accessibility for LATAM Airlines' home page — one of the highest-traffic pages in Latin American aviation</li>
          <li>Integrated personalization tools to deliver tailored content experiences to millions of passengers</li>
          <li>Developed features for the promotions backoffice, enabling marketing analysts to manage campaigns autonomously</li>
          <li>Contributed to micro-frontend architecture decisions and established frontend best practices</li>
          <li>Promoted to Software Architect in October 2024</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · Next.js · Node.js · TypeScript · Jest · Testing Library · Storybook · Vite
        </p>
        <Button text="Website" href="https://latamairlines.com" target="_blank" />
      </li>
      <li class="mb-10 ms-6">
        <span
          class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900"
        >
        </span>
        <h3 class="mb-1 text-lg font-semibold text-gray-900 dark:text-white">Globant <span class="text-sm font-normal text-gray-400 dark:text-gray-500">(client: LATAM Airlines)</span></h3>
        <span>
          <span> Web UI Developer Senior</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> December 2021 - July 2023</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Led frontend development for the home page of Latin America's largest airline, serving millions of monthly users across 10+ countries</li>
          <li>Architected and maintained multiple micro-frontends using React and Next.js (SSR), improving Core Web Vitals</li>
          <li>Built BFF APIs with Node.js and Express integrating personalization and promotions services</li>
          <li>Mentored mid-level engineers and contributed to code review culture</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · Next.js · Node.js · TypeScript · Redux · Styled Components · Zustand
        </p>
        <span>
          <span> Web UI Developer SSr Adv</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> August 2020 - December 2021</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Developed new features for LATAM Airlines' home page and promotional backoffice</li>
          <li>Built micro-frontend modules with React and Next.js via federated architecture</li>
          <li>Implemented Redis caching strategies to optimize API response times</li>
          <li>Set up and maintained Jenkins pipelines for CI/CD</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · Next.js · Node.js · Redux · Styled Components · Zustand
        </p>
        <Button text="Website" href="https://globant.com" target="_blank" />
      </li>
      <li class="mb-10 ms-6">
        <span
          class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900"
        >
        </span>
        <h3 class="mb-1 text-lg font-semibold text-gray-900 dark:text-white">Acid Labs Chile</h3>
        <span>
          <span> Software Engineer</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> May 2019 - August 2020</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Developed core modules of Ripley.com's e-commerce platform including home page, product catalog and campaign admin panel</li>
          <li>Built a payment gateway for Coca-Cola Embonor (Chile &amp; Peru) with Node.js, deployed on AWS EKS with Kubernetes</li>
          <li>Acted as subject matter expert during COVID-19, onboarding new engineers under accelerated timelines</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · Node.js · Express · Redis · MySQL · GitLab CI · AWS EKS · Kubernetes
        </p>
        <Button text="Website" href="https://acidlabs.com" target="_blank" />
      </li>
      <li class="mb-10 ms-6">
        <span
          class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900"
        >
        </span>
        <h3 class="mb-1 text-lg font-semibold text-gray-900 dark:text-white">INNSPIRAL</h3>
        <span>
          <span> Technology Analyst</span>
          <time class="block mb-2 text-sm font-normal leading-none text-gray-500"> June 2018 - May 2019</time>
        </span>
        <ul class="mb-4 list-disc list-inside text-base font-normal text-gray-500 dark:text-gray-400 space-y-1">
          <li>Built full-stack web applications for enterprise clients: innovation portfolio platform (GPI) and employee sentiment tool (Thermometer)</li>
          <li>Developed UI mockup for Chilena Consolidada Seguros Vida to validate personalized insurance hypothesis</li>
          <li>Owned full delivery lifecycle: requirements, database modeling, API development, GCP deployment and stakeholder demos</li>
        </ul>
        <p class="mb-4 text-sm font-normal text-gray-400 dark:text-gray-500">
          React · Node.js · Express · MySQL · GCP · Cloudflare · GitLab CI
        </p>
        <Button text="Website" href="https://innspiral.com" target="_blank" />
      </li>
    </ol>
  </div>
</WidgetWrapper>
