---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const { Content } = post;
---

<div class="blog-wrap">
  <header class="post-header reveal">
    <div class="post-header-meta">
      <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
      {post.category && (
        <>
          <span class="post-header-dot"></span>
          <a class="post-header-cat" href={getPermalink(post.category, 'category')}>
            {post.category.replaceAll('-', ' ')}
          </a>
        </>
      )}
      {post.readingTime && (
        <>
          <span class="post-header-dot"></span>
          <span>{post.readingTime} min read</span>
        </>
      )}
    </div>
    <h1 class="post-title">{post.title}</h1>
    {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
  </header>

  {post.image ? (
    <Image
      src={post.image}
      class="post-hero-img"
      widths={[800, 1200]}
      sizes="(max-width: 860px) 100vw, 860px"
      alt={post.excerpt || post.title}
      width={860}
      height={484}
      loading="eager"
      decoding="async"
    />
  ) : (
    <hr class="post-divider" />
  )}

  <div class="prose reveal">
    {Content ? <Content /> : <Fragment set:html={post.content || ''} />}
  </div>

  <div class="post-footer reveal">
    <PostTags tags={post.tags} />
  </div>
</div>
