---
import type { Post } from '~/types';
import { APP_BLOG } from '~/utils/config';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<li class="post-list-item reveal">
  <div class="post-card">
    <div>
      <div class="post-card-meta">
        <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
        {post.category && (
          <>
            <span class="post-card-dot"></span>
            <a class="post-card-cat" href={getPermalink(post.category, 'category')}>
              {post.category.replaceAll('-', ' ')}
            </a>
          </>
        )}
        {post.readingTime && (
          <>
            <span class="post-card-dot"></span>
            <span>{post.readingTime} min read</span>
          </>
        )}
      </div>
      <h2>
        {link ? <a href={link}>{post.title}</a> : post.title}
      </h2>
      {post.excerpt && <p>{post.excerpt}</p>}
      {post.tags && post.tags.length > 0 && (
        <div class="post-card-tags">
          {post.tags.map((tag) => (
            APP_BLOG?.tag?.isEnabled
              ? <a href={getPermalink(tag, 'tag')}>{tag}</a>
              : <span>{tag}</span>
          ))}
        </div>
      )}
    </div>
    {link && <span class="post-card-arrow" aria-hidden="true">↗</span>}
  </div>
</li>
