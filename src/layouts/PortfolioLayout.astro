---
interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'es';
  ogImage?: string;
  canonicalURL?: string;
}
const {
  title = 'Rodrigo Bustamante — Staff Frontend Engineer · Design Systems Architect',
  description = 'Rodrigo Bustamante — Staff Frontend Engineer & Design Systems Architect. 9 years building scalable frontend systems and design systems for global brands.',
  lang,
  ogImage = '/images/portrait-crop.png',
  canonicalURL = Astro.url.href,
} = Astro.props;

const ogImageAbs = new URL(ogImage, Astro.site ?? Astro.url).href;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rodrigo Bustamante',
  jobTitle: 'Staff Frontend Engineer · Design Systems Architect',
  url: 'https://rodrigobustamante.cl',
  image: ogImageAbs,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Madrid',
    addressCountry: 'ES',
  },
  sameAs: [
    'https://www.linkedin.com/in/rod-bustamante/',
    'https://github.com/rodrigobustamante',
  ],
});
---

<!doctype html>
<html lang={lang ?? 'en'} data-theme="light" data-lang={lang ?? 'en'} {...(lang ? { 'data-fixed-lang': lang } : {})}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- hreflang: cookie-based i18n — both langs resolve to the same URL -->
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="608" />
    <meta property="og:image:height" content="760" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={jsonLd} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preload" as="font" href="/fonts/newsreader-normal-latin.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/hanken-normal-latin.woff2" type="font/woff2" crossorigin />
    <slot name="head" />
    <style is:inline>
  /* ——— Self-hosted fonts ——— */
  @font-face {
    font-family: 'Newsreader';
    font-style: normal;
    font-weight: 300 500;
    font-display: optional;
    src: url('/fonts/newsreader-normal-latin-ext.woff2') format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  @font-face {
    font-family: 'Newsreader';
    font-style: normal;
    font-weight: 300 500;
    font-display: optional;
    src: url('/fonts/newsreader-normal-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Newsreader';
    font-style: italic;
    font-weight: 300 500;
    font-display: optional;
    src: url('/fonts/newsreader-italic-latin-ext.woff2') format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  @font-face {
    font-family: 'Newsreader';
    font-style: italic;
    font-weight: 300 500;
    font-display: optional;
    src: url('/fonts/newsreader-italic-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Hanken Grotesk';
    font-style: normal;
    font-weight: 400 600;
    font-display: optional;
    src: url('/fonts/hanken-normal-latin-ext.woff2') format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  @font-face {
    font-family: 'Hanken Grotesk';
    font-style: normal;
    font-weight: 400 600;
    font-display: optional;
    src: url('/fonts/hanken-normal-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }

  /* ——————————————————————————————————————————
     Design tokens
  —————————————————————————————————————————— */
  :root {
    --paper: oklch(0.972 0.013 79);
    --paper-2: oklch(0.945 0.016 78);
    --card: oklch(0.99 0.006 85);
    --ink: oklch(0.27 0.018 55);
    --ink-soft: oklch(0.42 0.02 52);
    --muted: oklch(0.46 0.018 55);
    --faint: oklch(0.60 0.015 60);
    --line: oklch(0.88 0.014 72);
    --line-soft: oklch(0.92 0.012 75);
    --accent: oklch(0.585 0.125 42);
    --accent-soft: color-mix(in oklab, oklch(0.585 0.125 42) 12%, transparent);
    --accent-ink: oklch(0.46 0.12 42);
    --serif: 'Newsreader', Georgia, 'Times New Roman', serif;
    --sans: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
    --maxw: 1080px;
    --pad: clamp(20px, 5vw, 64px);
  }

  :root[data-theme='dark'] {
    --paper: oklch(0.205 0.012 56);
    --paper-2: oklch(0.245 0.014 56);
    --card: oklch(0.255 0.014 56);
    --ink: oklch(0.94 0.012 80);
    --ink-soft: oklch(0.82 0.014 78);
    --muted: oklch(0.68 0.016 70);
    --faint: oklch(0.62 0.016 65);
    --line: oklch(0.36 0.016 58);
    --line-soft: oklch(0.31 0.014 58);
    --accent: oklch(0.72 0.12 48);
    --accent-soft: color-mix(in oklab, oklch(0.72 0.12 48) 16%, transparent);
    --accent-ink: oklch(0.78 0.12 50);
  }

  /* ——— Reset ——— */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 17px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    transition:
      background 0.4s ease,
      color 0.4s ease;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  button {
    font: inherit;
    color: inherit;
    background: none;
    border: 0;
    cursor: pointer;
  }
  img {
    display: block;
    max-width: 100%;
  }
  ::selection {
    background: var(--accent-soft);
    color: var(--accent-ink);
  }

  /* ——— Layout ——— */
  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  /* ——— Header ——— */
  .header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid transparent;
    transition:
      background 0.3s,
      border-color 0.3s,
      backdrop-filter 0.3s;
  }
  .header.scrolled {
    background: color-mix(in oklab, var(--paper) 85%, transparent);
    backdrop-filter: blur(10px) saturate(1.2);
    border-bottom-color: var(--line);
  }
  .header-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 18px var(--pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .wordmark-name {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .wordmark-dot {
    color: var(--accent);
    font-size: 20px;
    line-height: 1;
  }
  .header-nav {
    display: flex;
    gap: 26px;
  }
  .header-nav a {
    font-size: 14px;
    color: var(--ink-soft);
    position: relative;
    padding: 4px 0;
    transition: color 0.2s;
  }
  .header-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--accent);
    transition: right 0.25s ease;
  }
  .header-nav a:hover {
    color: var(--ink);
  }
  .header-nav a:hover::after {
    right: 0;
  }
  @media (max-width: 760px) {
    .header-nav {
      display: none;
    }
  }
  .header-tools {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    height: 36px;
    padding: 0 12px;
    min-width: 36px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 13px;
    color: var(--ink-soft);
    transition: all 0.2s;
  }
  .tool-btn:hover {
    border-color: var(--ink-soft);
    color: var(--ink);
  }
  .lang-btn .on {
    color: var(--accent-ink);
    font-weight: 600;
  }
  .lang-btn .off {
    color: var(--muted);
  }
  .lang-btn .slash {
    color: var(--line);
    margin: 0 1px;
  }

  /* ——— Hero ——— */
  .hero {
    padding: clamp(56px, 11vh, 130px) 0 clamp(40px, 7vh, 80px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  .hero-portrait {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 7px;
  }
  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-right {
      order: -1;
      max-width: 320px;
    }
  }
  .hero-avail {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    margin-bottom: 30px;
  }
  .hero-avail .pip {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: oklch(0.7 0.15 150);
    box-shadow: 0 0 0 4px color-mix(in oklab, oklch(0.7 0.15 150) 22%, transparent);
    flex-shrink: 0;
  }
  .hero-role {
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-ink);
    font-weight: 600;
    margin-bottom: 18px;
  }
  .hero-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(48px, 10vw, 104px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin-bottom: 30px;
  }
  .hero-pitch {
    font-family: var(--serif);
    font-size: clamp(20px, 2.6vw, 28px);
    line-height: 1.42;
    color: var(--ink-soft);
    max-width: 24ch;
    font-weight: 300;
    text-wrap: pretty;
    margin-bottom: 34px;
  }
  .hero-pitch em {
    color: var(--ink);
    font-style: italic;
  }
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 18px;
    margin-bottom: 30px;
    font-size: 14px;
    color: var(--muted);
  }
  .hero-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
  }
  .hero-stat:not(:last-child)::after {
    content: '';
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--faint);
    margin-left: 18px;
    align-self: center;
  }
  .hero-stat b {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 36px;
  }
  .hero-meta .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--faint);
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ——— Buttons ——— */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    height: 50px;
    padding: 0 24px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 500;
    border: 1px solid var(--line);
    color: var(--ink);
    transition: all 0.2s ease;
  }
  .btn svg {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn-primary {
    background: var(--accent);
    color: oklch(0.99 0.01 85);
    border-color: var(--accent);
  }
  :root[data-theme='dark'] .btn-primary {
    color: oklch(0.18 0.02 56);
  }
  .btn-primary:hover {
    box-shadow: 0 10px 26px -10px color-mix(in oklab, var(--accent) 70%, transparent);
  }
  .btn-ghost:hover {
    border-color: var(--ink-soft);
    background: var(--card);
  }

  /* ——— Section scaffold ——— */
  .section {
    padding: clamp(64px, 9vh, 110px) 0;
  }
  .section + .section {
    border-top: 1px solid var(--line-soft);
  }
  .section-head {
    margin-bottom: clamp(40px, 6vh, 64px);
  }
  .section-num {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--accent);
    margin-bottom: 10px;
    display: inline-block;
  }
  .section-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(32px, 5vw, 50px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .section-sub {
    font-size: 17px;
    color: var(--muted);
    max-width: 56ch;
    text-wrap: pretty;
  }

  /* ——— Experience timeline ——— */
  .entry {
    display: grid;
    grid-template-columns: 132px 1fr;
    gap: clamp(20px, 4vw, 52px);
    padding: clamp(28px, 4vh, 44px) 0;
  }
  .entry + .entry {
    border-top: 1px solid var(--line-soft);
  }
  .entry-years {
    font-family: var(--serif);
    font-size: 19px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .entry-sector {
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 6px;
  }
  .entry-loc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 14px;
    line-height: 1.4;
  }
  .entry-main {
    min-width: 0;
  }
  .entry-company {
    font-family: var(--serif);
    font-size: clamp(24px, 3.2vw, 32px);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .entry-highlight {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--accent-ink);
    font-weight: 500;
    margin-top: 10px;
    padding: 5px 12px 5px 10px;
    background: var(--accent-soft);
    border-radius: 999px;
  }
  .entry-highlight .star {
    font-size: 12px;
  }
  .role {
    margin-top: 26px;
  }
  .role-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .role-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
  }
  .role-period {
    font-size: 13px;
    color: var(--muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .role-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .role-bullets li {
    position: relative;
    padding-left: 22px;
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.55;
    text-wrap: pretty;
  }
  .role-bullets li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 11px;
    width: 7px;
    height: 1px;
    background: var(--accent);
  }
  .entry-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }
  .chip {
    font-size: 12.5px;
    color: var(--ink-soft);
    padding: 4px 11px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--card);
  }
  @media (max-width: 680px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .entry-aside {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
    }
    .entry-loc {
      margin-top: 0;
    }
    .role-head {
      gap: 4px;
    }
  }

  /* ——— Skills ——— */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2px;
    background: var(--line-soft);
    border: 1px solid var(--line-soft);
    border-radius: 14px;
    overflow: hidden;
  }
  .skill-col {
    background: var(--paper);
    padding: 26px 24px;
  }
  .skill-label {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--ink);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line-soft);
  }
  .skill-items {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .skill-items span {
    font-size: 15px;
    color: var(--ink-soft);
  }

  /* ——— Education ——— */
  .edu-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 60px);
  }
  @media (max-width: 720px) {
    .edu-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  .edu-school {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .edu-degree {
    font-size: 16px;
    color: var(--ink-soft);
    margin-top: 4px;
  }
  .edu-line {
    display: flex;
    gap: 12px;
    font-size: 13px;
    color: var(--muted);
    margin-top: 8px;
  }
  .edu-notes {
    font-size: 15px;
    color: var(--ink-soft);
    margin-top: 14px;
    line-height: 1.55;
    font-style: italic;
    font-family: var(--serif);
  }
  .sub-h {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
  }
  .facts-list {
    display: flex;
    flex-direction: column;
  }
  .facts-list .row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 18px;
    padding: 16px 0;
    border-top: 1px solid var(--line-soft);
  }
  .facts-list .row:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .facts-list .k {
    font-size: 14px;
    color: var(--ink);
    font-weight: 600;
  }
  .facts-list .v {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  @media (max-width: 460px) {
