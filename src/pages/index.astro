---
import PortfolioLayout from '~/layouts/PortfolioLayout.astro';
import SiteHeader from '~/components/portfolio/SiteHeader.astro';
import { useTranslations } from '~/i18n/ui';

const langCookie = Astro.cookies.get('lang');
const lang = (langCookie?.value === 'es' ? 'es' : 'en') as 'en' | 'es';
const { t, tl } = useTranslations(lang);
---

<PortfolioLayout
  title="Rodrigo Bustamante — Staff Frontend Engineer · Design Systems Architect"
  description="Rodrigo Bustamante — Staff Frontend Engineer & Design Systems Architect. 9 years building scalable frontend systems and design systems for global brands."
  lang={lang}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/images/portrait-crop.avif"
    type="image/avif"
    fetchpriority="high"
  />
  <SiteHeader lang={lang} variant="portfolio" homeHref="/" />

  <main>
    <!-- ——— Hero ——— -->
    <section id="top" class="hero">
      <div class="wrap hero-grid">
        <div class="hero-left">
          <div class="hero-role">Staff Frontend Engineer &amp; Design Systems Architect</div>
          <h1 class="hero-name">Rodrigo<br />Bustamante</h1>
          <p class="hero-pitch" set:html={t('hero.pitch')} />
          <div class="hero-stats">
            <span class="hero-stat"><b>9</b> {t('hero.stat.years')}</span>
            <span class="hero-stat"><b>50+</b> {t('hero.stat.teams')}</span>
            <span class="hero-stat"><b>{t('hero.stat.millions')}</b> {t('hero.stat.millions.sub')}</span>
            <span class="hero-stat"><b>10+</b> {t('hero.stat.countries')}</span>
          </div>
          <div class="hero-meta">
            {t('hero.location')}
            <span class="dot"></span>
            {t('hero.remote')}
          </div>
          <div class="hero-cta">
            <a class="btn btn-primary" href="#contact">
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><path d="M3 5.5h18v13H3zM3 6l9 6.5L21 6"></path></svg
              >
              {t('hero.cta.contact')}
            </a>
            <a class="btn btn-ghost" href="/uploads/cv-rodrigo-bustamante-general.pdf" target="_blank" rel="noopener">
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><path d="M12 3v12m0 0l-4.5-4.5M12 15l4.5-4.5M4.5 20.5h15"></path></svg
              >
              {t('hero.cta.cv')}
            </a>
          </div>
        </div>
        <div class="hero-right">
          <picture>
            <source srcset="/images/portrait-crop.avif" type="image/avif" />
            <source srcset="/images/portrait-crop.webp" type="image/webp" />
            <img
              src="/images/portrait-crop.png"
              alt="Rodrigo Bustamante"
              class="hero-portrait"
              width="608"
              height="760"
              fetchpriority="high"
              loading="eager"
            />
          </picture>
        </div>
      </div>
    </section>

    <!-- ——— Experience ——— -->
    <section id="work" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">01</span>
          <h2 class="section-title">{t('exp.title')}</h2>
          <p class="section-sub">{t('exp.sub')}</p>
        </div>

        <div class="timeline">
          <!-- Hangar Design System — LATAM Airlines -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">Oct 2024 — Mar 2026</div>
              <div class="entry-sector">{t('exp.hangar.sector')}</div>
              <div class="entry-loc">{t('exp.hangar.loc')}</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">Hangar Design System — LATAM Airlines</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.hangar.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Software Architect</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.hangar.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">React</span>
                <span class="chip">React Native</span>
                <span class="chip">Next.js</span>
                <span class="chip">TypeScript</span>
                <span class="chip">GCP</span>
                <span class="chip">Terraform Cloud</span>
                <span class="chip">GitLab CI</span>
                <span class="chip">Docker</span>
                <span class="chip">Redis</span>
                <span class="chip">Storybook</span>
              </div>
              <a class="cs-link" href="/work/hangar-design-system">{t('exp.hangar.cs')}</a>
            </div>
          </article>

          <!-- Digital Marketing Engage — LATAM Airlines -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">Jul 2023 — Sep 2024</div>
              <div class="entry-sector">{t('exp.dme-latam.sector')}</div>
              <div class="entry-loc">{t('exp.dme-latam.loc')}</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">Digital Marketing Engage — LATAM Airlines</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.dme-latam.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Senior Software Engineer</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.dme-latam.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">React</span>
                <span class="chip">Next.js</span>
                <span class="chip">TypeScript</span>
                <span class="chip">Node.js</span>
                <span class="chip">Express</span>
                <span class="chip">Redis</span>
                <span class="chip">Jenkins</span>
                <span class="chip">Micro-frontends</span>
              </div>
            </div>
          </article>

          <!-- Digital Marketing Engage — Globant / LATAM Airlines -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">Aug 2020 — Jul 2023</div>
              <div class="entry-sector">{t('exp.dme-globant.sector')}</div>
              <div class="entry-loc">{t('exp.dme-globant.loc')}</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">Digital Marketing Engage — LATAM Airlines</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.dme-globant.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Web UI Developer — Senior / SSr Adv</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.dme-globant.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">React</span>
                <span class="chip">Next.js</span>
                <span class="chip">TypeScript</span>
                <span class="chip">Node.js</span>
                <span class="chip">Express</span>
                <span class="chip">Redis</span>
                <span class="chip">Jenkins</span>
                <span class="chip">Micro-frontends</span>
              </div>
            </div>
          </article>

          <!-- Simple — Ripley.com (SME) -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">Apr 2020 — Aug 2020</div>
              <div class="entry-sector">{t('exp.simple-sme.sector')}</div>
              <div class="entry-loc">Santiago, Chile</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">Simple — Ripley.com</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.simple-sme.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Subject Matter Expert</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.simple-sme.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">React</span>
                <span class="chip">Node.js</span>
                <span class="chip">Express</span>
                <span class="chip">Redis</span>
                <span class="chip">imgix</span>
                <span class="chip">Heroku</span>
                <span class="chip">GitLab CI</span>
              </div>
            </div>
          </article>

          <!-- eCommerce Gateway — Coca-Cola / Embonor -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">Feb 2020 — Apr 2020</div>
              <div class="entry-sector">{t('exp.gateway.sector')}</div>
              <div class="entry-loc">Santiago, Chile</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">eCommerce Gateway — Coca-Cola / Embonor</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.gateway.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Backend Developer</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.gateway.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">Node.js</span>
                <span class="chip">Express</span>
                <span class="chip">MySQL</span>
                <span class="chip">AWS EKS</span>
                <span class="chip">Kubernetes</span>
                <span class="chip">GitLab CI</span>
                <span class="chip">Kiphu</span>
              </div>
            </div>
          </article>

          <!-- Simple — Ripley.com (FullStack) -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">May 2019 — Feb 2020</div>
              <div class="entry-sector">{t('exp.simple-fs.sector')}</div>
              <div class="entry-loc">Santiago, Chile</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">Simple — Ripley.com</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.simple-fs.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">FullStack Developer</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.simple-fs.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">React</span>
                <span class="chip">Node.js</span>
                <span class="chip">Express</span>
                <span class="chip">Redis</span>
                <span class="chip">imgix</span>
                <span class="chip">Heroku</span>
                <span class="chip">GitLab CI</span>
              </div>
            </div>
          </article>

          <!-- INNSPIRAL -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">2018 — 2019</div>
              <div class="entry-sector">{t('exp.innspiral.sector')}</div>
              <div class="entry-loc">Santiago, Chile</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">INNSPIRAL</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.innspiral.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Technology Analyst</span>
                  <span class="role-period">Jun 2018 — May 2019</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.innspiral.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">Node.js</span>
                <span class="chip">React</span>
                <span class="chip">SQL</span>
                <span class="chip">Cloud</span>
              </div>
            </div>
          </article>

          <!-- Earlier roles -->
          <article class="entry reveal">
            <aside class="entry-aside">
              <div class="entry-years">2015 — 2018</div>
              <div class="entry-sector">{t('exp.earlier.sector')}</div>
              <div class="entry-loc">Santiago, Chile</div>
            </aside>
            <div class="entry-main">
              <h3 class="entry-company">{t('exp.earlier.title')}</h3>
              <div class="entry-highlight">
                <span class="star">✦</span>
                {t('exp.earlier.highlight')}
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Software Engineer — Ormasoft</span>
                  <span class="role-period">Feb 2018 — May 2018</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.earlier.ormasoft.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">Software Engineer Intern — Análisis Ltda.</span>
                  <span class="role-period">Sep 2017 — Dec 2017</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.earlier.analisis.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="role">
                <div class="role-head">
                  <span class="role-title">{t('exp.earlier.ta-title')}</span>
                  <span class="role-period">Mar 2015 — Dec 2017</span>
                </div>
                <ul class="role-bullets">
                  {tl('exp.earlier.duoc.bullets').map(b => <li>{b}</li>)}
                </ul>
              </div>
              <div class="entry-stack">
                <span class="chip">Angular</span>
                <span class="chip">Aurelia</span>
                <span class="chip">D3.js</span>
                <span class="chip">Node.js</span>
                <span class="chip">SQL</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ——— Skills ——— -->
    <section id="skills" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">02</span>
          <h2 class="section-title">Skills</h2>
          <p class="section-sub">{t('skills.sub')}</p>
        </div>
        <div class="skills-grid reveal">
          <div class="skill-col">
            <div class="skill-label">Frontend</div>
            <div class="skill-items">
              <span>React</span>
              <span>Next.js</span>
              <span>TypeScript</span>
              <span>JavaScript (ES6+)</span>
              <span>Async JS</span>
              <span>Web Workers</span>
              <span>Webpack</span>
            </div>
          </div>
          <div class="skill-col">
            <div class="skill-label">{t('skills.architecture')}</div>
            <div class="skill-items">
              <span>Design Systems</span>
              <span>Micro-frontends</span>
              <span>System Design</span>
              <span>SOLID</span>
              <span>TDD</span>
              <span>CI/CD</span>
            </div>
          </div>
          <div class="skill-col">
            <div class="skill-label">{t('skills.cloud')}</div>
            <div class="skill-items">
              <span>Google Cloud (GCP)</span>
              <span>GitLab CI</span>
              <span>Docker</span>
              <span>Redis</span>
              <span>MySQL</span>
              <span>Node.js</span>
            </div>
          </div>
          <div class="skill-col">
            <div class="skill-label">{t('skills.viz')}</div>
            <div class="skill-items">
              <span>D3.js</span>
              <span>HTML Canvas</span>
              <span>Google Maps API</span>
              <span>Lottie</span>
              <span>Python</span>
              <span>React Native</span>
            </div>
          </div>
          <div class="skill-col">
            <div class="skill-label">Testing</div>
            <div class="skill-items">
              <span>Jest</span>
              <span>Cypress</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ——— Projects ——— -->
    <section id="projects" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">03</span>
          <h2 class="section-title">{t('projects.title')}</h2>
          <p class="section-sub">{t('projects.sub')}</p>
        </div>
        <div class="projects-grid reveal">
          <article class="project-card">
            <div class="project-head">
              <h3 class="project-name">{t('projects.pace.title')}</h3>
              <span class="project-status">{t('projects.pace.status')}</span>
            </div>
            <p class="project-desc">{t('projects.pace.desc')}</p>
            <div class="project-stack">
              <span class="chip">Next.js 14</span>
              <span class="chip">Expo</span>
              <span class="chip">TypeScript</span>
              <span class="chip">Gemini 2.5 Flash</span>
              <span class="chip">Strava API</span>
            </div>
            <div class="project-links">
              <!-- LINK_REPO: reemplaza # con la URL real del repositorio -->
              <a class="project-link" href="#" aria-label="PACE repo">{t('projects.repo')}</a>
              <!-- LINK_DEMO: reemplaza # con la URL real del demo -->
              <a class="project-link" href="#" aria-label="PACE demo">{t('projects.demo')}</a>
            </div>
          </article>
          <article class="project-card">
            <div class="project-head">
              <h3 class="project-name">{t('projects.intervalo.title')}</h3>
              <span class="project-status">{t('projects.intervalo.status')}</span>
            </div>
            <p class="project-desc">{t('projects.intervalo.desc')}</p>
            <div class="project-stack">
              <span class="chip">Next.js</span>
              <span class="chip">MapLibre GL JS</span>
              <span class="chip">Web Audio API</span>
              <span class="chip">GTFS</span>
              <span class="chip">TypeScript</span>
            </div>
            <div class="project-links">
              <!-- LINK_REPO: reemplaza # con la URL real del repositorio -->
              <a class="project-link" href="#" aria-label="Intervalo repo">{t('projects.repo')}</a>
              <!-- LINK_DEMO: reemplaza # con la URL real del demo -->
              <a class="project-link" href="#" aria-label="Intervalo demo">{t('projects.demo')}</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ——— Education & beyond ——— -->
    <section id="education" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">04</span>
          <h2 class="section-title">{t('edu.title')}</h2>
          <p class="section-sub">{t('edu.sub')}</p>
        </div>
        <div class="edu-layout reveal">
          <div>
            <div class="sub-h">{t('edu.section')}</div>
            <div class="edu-card">
              <div class="edu-school">Duoc UC</div>
              <div class="edu-degree">{t('edu.degree')}</div>
              <div class="edu-line">
                <span>Santiago, Chile</span>
                <span>·</span>
                <span>2014 — 2017</span>
              </div>
              <div class="edu-notes">{t('edu.notes')}</div>
            </div>
          </div>
          <div>
            <div class="sub-h">{t('edu.details')}</div>
            <div class="facts-list">
              <div class="row">
                <div class="k">{t('edu.industries.k')}</div>
                <div class="v">{t('edu.industries.v')}</div>
              </div>
              <div class="row">
                <div class="k">{t('edu.languages.k')}</div>
                <div class="v">{t('edu.languages.v')}</div>
              </div>
              <div class="row">
                <div class="k">{t('edu.work-auth.k')}</div>
                <div class="v">{t('edu.work-auth.v')}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ——— Writing ——— -->
    <section id="writing" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">05</span>
          <h2 class="section-title">{t('writing.title')}</h2>
          <p class="section-sub">{t('writing.sub')}</p>
        </div>
        <div class="posts reveal">
          {lang === 'es' ? (
            <>
              <a class="post" href="/blog/es/rendimiento-web-rendimiento-especulativo-guia">
                <div class="post-meta">
                  <span class="post-cat">Performance</span>
                  <span class="dot"></span>
                  <span>12 Mar 2025</span>
                  <span class="dot"></span>
                  <span>8 min de lectura</span>
                </div>
                <h3 class="post-title">Speculative Rendering — Mejorando el performance web</h3>
                <p class="post-excerpt">
                  Qué es el speculative rendering, cómo mejora el performance y buenas prácticas para implementarlo en tu sitio.
                </p>
                <div class="post-foot">
                  <div class="post-tags"><span>#performance</span><span>#seo</span></div>
                  <span class="post-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 18L18 6M9 6h9v9"></path></svg></span>
                </div>
              </a>
              <a class="post" href="/blog/es/core-web-vitals-guia-completa-para-principiantes">
                <div class="post-meta">
                  <span class="post-cat">Tutoriales</span>
                  <span class="dot"></span>
                  <span>6 Mar 2025</span>
                  <span class="dot"></span>
                  <span>12 min de lectura</span>
                </div>
                <h3 class="post-title">Core Web Vitals — Guía completa para principiantes</h3>
                <p class="post-excerpt">
                  Todo sobre Core Web Vitals — qué son, por qué importan y cómo mejorar performance, accesibilidad y SEO.
                </p>
                <div class="post-foot">
                  <div class="post-tags"><span>#performance</span><span>#a11y</span><span>#seo</span></div>
                  <span class="post-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 18L18 6M9 6h9v9"></path></svg></span>
                </div>
              </a>
            </>
          ) : (
            <>
              <a class="post" href="/blog/en/speculative-rendering-web-performance-guide">
                <div class="post-meta">
                  <span class="post-cat">Performance</span>
                  <span class="dot"></span>
                  <span>Mar 12, 2025</span>
                  <span class="dot"></span>
                  <span>8 min read</span>
                </div>
                <h3 class="post-title">Speculative Rendering — Enhancing Web Performance</h3>
                <p class="post-excerpt">
                  What speculative rendering is, how it improves performance, and best practices for implementing it on your site.
                </p>
                <div class="post-foot">
                  <div class="post-tags"><span>#performance</span><span>#seo</span></div>
                  <span class="post-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 18L18 6M9 6h9v9"></path></svg></span>
