          <div class="skill-col">
            <div class="skill-label">Testing</div>
            <div class="skill-items">
              <span>Jest</span>
              <span>Cypress</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ——— Education & beyond ——— -->
    <section id="education" class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="section-num">03</span>
          <h2 class="section-title">
            <span class="lng-en">Education &amp; beyond</span>
            <span class="lng-es">Formación y más</span>
          </h2>
          <p class="section-sub lng-en">Foundations and the details recruiters ask about.</p>
          <p class="section-sub lng-es">Las bases y los detalles que preguntan los reclutadores.</p>
        </div>
        <div class="edu-layout reveal">
          <div>
            <div class="sub-h">
              <span class="lng-en">Education</span>
              <span class="lng-es">Formación</span>
            </div>
            <div class="edu-card">
              <div class="edu-school">Duoc UC</div>
              <div class="edu-degree">
                <span class="lng-en">IT Engineering</span>
                <span class="lng-es">Ingeniería en Informática</span>
              </div>
              <div class="edu-line">
                <span>Santiago, Chile</span>
                <span>·</span>
                <span>2014 — 2017</span>
              </div>
              <div class="edu-notes lng-en">
                Graduated with Distinction. Winner of the CITT Annual Competition 2017.
              </div>
              <div class="edu-notes lng-es">Graduado con Distinción. Ganador del Concurso Anual CITT 2017.</div>
            </div>
          </div>
          <div>
            <div class="sub-h">
              <span class="lng-en">Details</span>
              <span class="lng-es">Detalles</span>
            </div>
            <div class="facts-list">
              <div class="row">
                <div class="k">
                  <span class="lng-en">Industries</span>
                  <span class="lng-es">Industrias</span>
                </div>
                <div class="v">
                  <span class="lng-en">Retail, payments, healthcare, corporate innovation and aviation.</span>
